# ─── Database (Phase 2) ──────────────────────────────────────────────────────
# Neon Postgres pooled connection string. Create a free project at neon.tech,
# then copy the "pooled" connection string here.
# Format: postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ─── Google Sheets mirror (Phase 2) ─────────────────────────────────────────
# Sheet ID from the URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=
# Tab name inside the spreadsheet. Defaults to Entries.
GOOGLE_SHEET_NAME=Entries
# Full service-account JSON as a single-line string (escape newlines)
GOOGLE_SERVICE_ACCOUNT_KEY=

# ─── Football feed (Phase 3) ─────────────────────────────────────────────────
# Optional: override the openfootball 2026 feed URL (defaults to the public one).
WORLDCUP_FEED_URL=
# Optional: enables the football-data.org fallback (documented stub for now).
FOOTBALL_DATA_API_KEY=

# ─── Email via Resend (Phase 4) ──────────────────────────────────────────────
RESEND_API_KEY=
# Verified sending domain — e.g. noreply@411sweepstake.com
EMAIL_FROM=

# ─── Admin (Phase 4) ─────────────────────────────────────────────────────────
# Simple password protecting the /admin route
ADMIN_PASSWORD=

# ─── Site access ─────────────────────────────────────────────────────────────
# Optional shared password protecting the public site. Leave blank for no gate.
SITE_PASSWORD=
